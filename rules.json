        {
            "name": "palm oil",
            "reason": "High in saturated fat; linked to raised cardiovascular risk markers in some reviews. Retained pending fresh source review.",
            "source": "Harvard Health",
            "penalty": 8
        },
        {
            "name": "high fructose corn syrup",
            "reason": "Added sweetener associated with metabolic dysfunction, raised triglycerides, and fatty liver in several studies. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 12
        },
        {
            "name": "corn syrup",
            "reason": "Refined caloric sweetener contributing added sugars with no nutritional benefit. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 10
        },
        {
            "name": "hydrogenated",
            "reason": "Partially hydrogenated oils are the source of industrial trans fats, which the FDA ordered phased out of the food supply. Retained pending fresh source review.",
            "source": "FDA / Internal review",
            "penalty": 20
        },
        {
            "name": "aspartame",
            "reason": "Artificial sweetener classified by IARC in 2023 as possibly carcinogenic to humans (Group 2B). Retained pending fresh source review.",
            "source": "IARC/WHO 2023",
            "penalty": 8
        },
        {
            "name": "sucralose",
            "reason": "Artificial sweetener linked in animal/microbiome studies to gut microbiome alteration and inflammation. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 7
        },
        {
            "name": "maltodextrin",
            "reason": "Highly refined starch with high glycemic index; possible adverse effects on gut microbiota. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 6
        },
        {
            "name": "sodium nitrite",
            "reason": "Curing agent in processed meats associated with colorectal cancer risk via nitrosamine formation. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 12
        },
        {
            "name": "sodium nitrate",
            "reason": "Curing agent that converts to nitrite; processed-meat nitrates associated with cancer risk in cohort studies. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 11
        },
        {
            "name": "titanium dioxide",
            "reason": "Whitening agent (E171) no longer considered safe as a food additive by EFSA (2021); banned in the EU due to genotoxicity concerns. Retained pending fresh source review.",
            "source": "EFSA 2021",
            "penalty": 14
        },
        {
            "name": "potassium bromate",
            "reason": "Flour-treatment agent shown to be a renal carcinogen in animal studies; banned in many jurisdictions. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 18
        },
        {
            "name": "brominated vegetable oil",
            "reason": "Emulsifier whose food-use authorization was revoked by the FDA over toxicity concerns. Retained pending fresh source review.",
            "source": "FDA",
            "penalty": 16
        },
        {
            "name": "tbhq",
            "reason": "Synthetic antioxidant preservative with cyto/genotoxicity concerns in laboratory studies. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 9
        },
        {
            "name": "azodicarbonamide",
            "reason": "Flour bleaching/dough conditioning agent; degradation products raise safety concerns. Retained pending fresh source review.",
            "source": "FDA / Internal review",
            "penalty": 10
        },
        {
            "name": "propylparaben",
            "reason": "Preservative flagged as a potential endocrine-disrupting chemical. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 9
        },
        {
            "name": "bha",
            "reason": "Synthetic antioxidant preservative listed as reasonably anticipated to be a human carcinogen; under FDA assessment. Retained pending fresh source review.",
            "source": "Internal review",
            "penalty": 11
        }
